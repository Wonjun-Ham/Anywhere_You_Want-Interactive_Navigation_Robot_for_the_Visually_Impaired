<!-- ROS Node Output Options
When creating a node in a ROS launch file, 
the output attribute has four possible options:
Options
screen (default)
Output goes to the terminal/console where you launched the fil
log
Redirects output to log files in ~/.ros/log/
Useful for reducing console clutter
both
Sends output to both screen and log files
Useful for debugging while maintaining logs
none
Suppresses all output
Useful for nodesthat generate excessive output you want to ignore
 -->

<launch>
    <!-- Launch the camera -->
    <node name="usb_cam" pkg="usb_cam" type="usb_cam_node" output="screen" >
        <rosparam file="../config/camera_front.yaml" command="load" />
    </node>

    <!-- Launch the joy stick node -->
    <node pkg="joy" type="joy_node" name="joy_node">
         <rosparam file="../config/joystick.yaml" command="load" />
    </node>

    <!-- Launch the locobot with only use_base -->
    <include file="$(find kobuki_node)/launch/minimal.launch"></include> 
    
    <!-- config에 있는 cmd_vel_mux.yaml을 여기 대신 써야겠음 -->
    <!-- velocity mulitplexer -->
    <arg name="nodelet_manager_name"  value="nodelet_manager"/>
    <arg name="config_file"           value="/home/racecar/vint_release/gnm-v2/deployment/config/cmd_vel_mux.yaml"/>
  
    <!-- nodelet manager -->
    <node pkg="nodelet" type="nodelet" name="$(arg nodelet_manager_name)" args="manager"/>
    
    <!-- velocity mulitplexer -->
    <include file="$(find yocs_cmd_vel_mux)/launch/cmd_vel_mux.launch">
        <arg name="nodelet_manager_name"  value="$(arg nodelet_manager_name)"/>
        <arg name="config_file"           value="$(arg config_file)"/>
    </include>

</launch>
